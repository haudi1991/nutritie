---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Puie Radu, Tehnician Nutriționist" padded>
  <section class="contact">

    <div class="contact-header">
      <p class="eyebrow">Contact</p>
      <h1>Hai să vorbim</h1>
      <p class="intro">Prima consultație e gratuită — 30 de minute, online, fără obligații.</p>
    </div>

    <!-- Calendly CTA -->
    <a href="https://calendly.com/radupuie/30min" target="_blank" rel="noopener noreferrer" class="calendly-card">
      <div class="calendly-card-left">
        <div class="calendly-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <div>
          <p class="calendly-label">Prima consultație gratuită</p>
          <p class="calendly-sub">30 min · Online · Fără obligații</p>
        </div>
      </div>
      <span class="calendly-arrow">Programează →</span>
    </a>

    <!-- WhatsApp card cu QR -->
    <div class="wa-card">
      <div class="wa-card-left">
        <div class="wa-logo">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </div>
        <div class="wa-text">
          <p class="wa-title">Scrie-mi pe WhatsApp</p>
          <p class="wa-sub">Răspund de obicei în câteva ore</p>
          <a href="https://wa.me/40724212779" target="_blank" rel="noopener noreferrer" class="wa-btn">
            Deschide chat →
          </a>
        </div>
      </div>
      <div class="wa-qr">
        <img
          src="https://api.qrserver.com/v1/create-qr-code/?size=130x130&data=https%3A%2F%2Fwa.me%2F40724212779&bgcolor=128C7E&color=ffffff&margin=10"
          alt="QR Code WhatsApp Puie Radu"
          width="130"
          height="130"
        />
        <p class="qr-hint">Scanează cu telefonul</p>
      </div>
    </div>

    <!-- Rânduri contact vizibile cu copy -->
    <div class="contact-rows">

      <div class="contact-row">
        <a href="tel:+40724212779" class="contact-row-link">
          <div class="cr-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .92h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div class="cr-text">
            <span class="cr-label">Telefon</span>
            <span class="cr-value">0724 212 779</span>
          </div>
        </a>
        <button class="copy-btn" data-copy="0724 212 779" aria-label="Copiază numărul de telefon">
          <svg class="icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          <svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>

      <div class="contact-row">
        <a href="mailto:puieradu14@gmail.com" class="contact-row-link">
          <div class="cr-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div class="cr-text">
            <span class="cr-label">Email</span>
            <span class="cr-value">puieradu14@gmail.com</span>
          </div>
        </a>
        <button class="copy-btn" data-copy="puieradu14@gmail.com" aria-label="Copiază adresa de email">
          <svg class="icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          <svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>

      <a href="https://eatntrack.ro/coaches/radu-p" target="_blank" rel="noopener noreferrer" class="contact-row contact-row-link contact-row--link">
        <div class="cr-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
        </div>
        <div class="cr-text">
          <span class="cr-label">Profil</span>
          <span class="cr-value">EatNtrack</span>
        </div>
        <svg class="cr-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>

    </div>

  </section>

  <style>
    .contact {
      max-width: 520px;
    }

    .contact-header {
      margin-bottom: 2rem;
    }
    .contact-header h1 {
      font-size: 2.2rem;
      margin: 0.25rem 0 0.5rem;
    }
    .intro {
      color: var(--text-muted);
      font-size: 1rem;
    }

    /* WhatsApp card */
    .wa-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      background: linear-gradient(135deg, #075E54 0%, #128C7E 60%, #25d366 100%);
      border-radius: var(--r-md);
      padding: 1.75rem;
      margin-bottom: 1rem;
      box-shadow: 0 8px 32px rgba(7,94,84,.25);
      overflow: hidden;
      position: relative;
    }
    .wa-card::before {
      content: '';
      position: absolute;
      top: -40px;
      right: 100px;
      width: 180px;
      height: 180px;
      background: rgba(255,255,255,.04);
      border-radius: 50%;
      pointer-events: none;
    }
    .wa-card-left {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
    }
    .wa-logo {
      width: 56px;
      height: 56px;
      background: rgba(255,255,255,.15);
      border-radius: var(--r-md);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      flex-shrink: 0;
      backdrop-filter: blur(4px);
    }
    .wa-text {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
    .wa-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #fff;
      margin: 0;
    }
    .wa-sub {
      font-size: 0.8rem;
      color: rgba(255,255,255,.7);
      margin: 0 0 0.75rem;
    }
    .wa-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: #fff;
      color: #075E54;
      font-weight: 700;
      font-size: 0.875rem;
      padding: 0.5rem 1.1rem;
      border-radius: var(--r-sm);
      text-decoration: none;
      transition: all 0.15s;
      width: fit-content;
    }
    .wa-btn:hover {
      background: rgba(255,255,255,.9);
      transform: translateY(-1px);
    }
    .wa-qr {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      flex-shrink: 0;
    }
    .wa-qr img {
      border-radius: var(--r-sm);
      display: block;
    }
    .qr-hint {
      font-size: 0.68rem;
      color: rgba(255,255,255,.65);
      text-align: center;
      max-width: 110px;
      line-height: 1.3;
      margin: 0;
    }

    /* Calendly card */
    .calendly-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      background: linear-gradient(135deg, var(--ink-950) 0%, var(--ink-800) 100%);
      color: #fff;
      border-radius: var(--r-md);
      padding: 1.25rem 1.5rem;
      text-decoration: none;
      margin-bottom: 1rem;
      transition: opacity 0.15s, transform 0.15s;
      box-shadow: var(--shadow-md);
    }
    .calendly-card:hover {
      opacity: 0.92;
      transform: translateY(-1px);
    }
    .calendly-card-left {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .calendly-icon {
      width: 44px;
      height: 44px;
      background: var(--accent);
      border-radius: var(--r-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .calendly-label {
      font-size: 1rem;
      font-weight: 700;
      color: #fff;
      margin: 0 0 0.2rem;
    }
    .calendly-sub {
      font-size: 0.8rem;
      color: rgba(255,255,255,.6);
      margin: 0;
    }
    .calendly-arrow {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--accent-lit);
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* Rânduri contact */
    .contact-rows {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .contact-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--r-sm);
      padding: 0.75rem 1rem;
      box-shadow: var(--shadow-sm);
      transition: border-color 0.15s;
    }
    .contact-row:hover { border-color: var(--accent); }
    .contact-row-link {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex: 1;
      text-decoration: none;
      color: var(--text);
    }
    .contact-row--link { cursor: pointer; }
    .cr-icon {
      width: 36px;
      height: 36px;
      background: var(--accent-50);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent);
      flex-shrink: 0;
    }
    .cr-text {
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }
    .cr-label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-muted);
    }
    .cr-value {
      font-size: 0.925rem;
      font-weight: 600;
      color: var(--text);
    }
    .cr-arrow {
      margin-left: auto;
      color: var(--text-muted);
      flex-shrink: 0;
    }
    /* Buton copy */
    .copy-btn {
      margin-left: auto;
      background: none;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.35rem 0.5rem;
      cursor: pointer;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      transition: all 0.15s;
      flex-shrink: 0;
    }
    .copy-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: var(--accent-50);
    }
    .copy-btn.done {
      border-color: #22c55e;
      color: #22c55e;
      background: #f0fdf4;
    }
    .copy-btn .icon-copy { display: block; }
    .copy-btn .icon-check { display: none; }
    .copy-btn.done .icon-copy { display: none; }
    .copy-btn.done .icon-check { display: block; }
  </style>

  <script is:inline>
    document.querySelectorAll('.copy-btn').forEach(function(btn) {
      btn.addEventListener('click', async function() {
        const text = btn.dataset.copy;
        try {
          await navigator.clipboard.writeText(text);
          btn.classList.add('done');
          setTimeout(function() { btn.classList.remove('done'); }, 1800);
        } catch(e) {}
      });
    });
  </script>
</Layout>
