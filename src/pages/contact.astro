---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Puie Radu, Tehnician Nutriționist" padded>
  <section class="contact">
    <h1>Contact</h1>
    <div class="free-consult-banner">
      🎁 <strong>Prima consultație este gratuită</strong> — 30 de minute, online, fără obligații.
      <a href="https://calendly.com/radupuie/30min" target="_blank" rel="noopener noreferrer">Programează acum →</a>
    </div>
    <p class="intro">Ai întrebări sau vrei să programezi o consultație? Scrie-mi sau sună-mă direct.</p>

    <ul class="contact-list">
      <li>
        <span class="contact-label">📞 Telefon</span>
        <a href="tel:+40724212779">0724 212 779</a>
      </li>
      <li>
        <span class="contact-label">💬 WhatsApp</span>
        <a href="https://wa.me/40724212779" target="_blank" rel="noopener noreferrer">
          Scrie-mi pe WhatsApp
        </a>
      </li>
      <li>
        <span class="contact-label">✉️ Email</span>
        <a href="mailto:puieradu14@gmail.com">puieradu14@gmail.com</a>
      </li>
      <li>
        <span class="contact-label">🥗 EatNtrack</span>
        <a href="https://eatntrack.ro/coaches/radu-p" target="_blank" rel="noopener noreferrer">
          eatntrack.ro/coaches/radu-p
        </a>
      </li>
    </ul>

    <a href="https://wa.me/40724212779" target="_blank" rel="noopener noreferrer" class="whatsapp-btn">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Contactează-mă pe WhatsApp
    </a>
  </section>

  <style>
    .contact {
      max-width: 560px;
    }
    h1 {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }
    .free-consult-banner {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
      background: #f0fdfa;
      border: 1px solid #5eead4;
      border-radius: 10px;
      padding: 0.9rem 1.2rem;
      margin: 1rem 0 1.5rem;
      font-size: 0.95rem;
      color: #0f766e;
    }
    .free-consult-banner a {
      color: #0f766e;
      font-weight: 700;
      text-decoration: underline;
      white-space: nowrap;
    }
    .free-consult-banner a:hover { color: #0d1117; }
    .intro {
      color: #555;
      margin-bottom: 2rem;
    }
    .contact-list {
      list-style: none;
      padding: 0;
      margin: 0 0 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .contact-list li {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem 1.25rem;
      background: #f8f7f4;
      border: 1px solid #d4eddf;
      border-radius: 8px;
    }
    .contact-label {
      font-weight: 600;
      color: #1a1a1a;
      min-width: 120px;
    }
    .contact-list a {
      color: #0d9488;
      text-decoration: none;
      font-weight: 500;
    }
    .contact-list a:hover {
      text-decoration: underline;
    }
    .whatsapp-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: #25d366;
      color: white;
      padding: 0.85rem 1.8rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      transition: background 0.2s;
    }
    .whatsapp-btn:hover {
      background: #1ebe5a;
    }
    .whatsapp-btn svg {
      width: 1.3rem;
      height: 1.3rem;
    }
  </style>
</Layout>
