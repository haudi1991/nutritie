---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title="Puie Radu — Tehnician Nutriționist">
  <section class="hero">
    <h1>Salut, sunt Puie Radu</h1>
    <p class="tagline">Tehnician Nutriționist</p>
    <p class="subtitle">
      Pasionat de nutriția echilibrată și de schimbări sustenabile ale stilului de viață.
      Te ajut să îți atingi obiectivele fără diete restrictive, adaptat nevoilor tale reale.
    </p>
    <div class="hero-ctas">
      <a href="/contact" class="cta">Programează o consultație</a>
      <a href="/despre" class="cta cta-secondary">Află mai multe despre mine</a>
    </div>
  </section>

  <section class="benefits">
    <div class="benefit-card">
      <span class="benefit-icon">🥗</span>
      <h3>Fără diete stricte</h3>
      <p>Adaptăm alimentația la viața ta reală, nu invers.</p>
    </div>
    <div class="benefit-card">
      <span class="benefit-icon">📚</span>
      <h3>Educație nutrițională</h3>
      <p>Înțelegi ce mănânci și de ce — nu urmezi reguli oarbe.</p>
    </div>
    <div class="benefit-card">
      <span class="benefit-icon">🎯</span>
      <h3>Obiective clare</h3>
      <p>Slăbit sănătos, relație mai bună cu mâncarea, obiceiuri durabile.</p>
    </div>
  </section>

  <section>
    <h2>Articole recente</h2>
    {latestPosts.length === 0 && <p>Primele articole vor apărea aici în curând.</p>}
    <ul class="post-list">
      {latestPosts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <p>{post.data.description}</p>
        </li>
      ))}
    </ul>
    {latestPosts.length > 0 && <p><a href="/blog">Vezi toate articolele →</a></p>}
  </section>

  <style>
    .hero {
      text-align: center;
      padding: 3.5rem 0 2.5rem;
    }
    .hero h1 {
      font-size: 2.4rem;
      margin-bottom: 0.3rem;
    }
    .tagline {
      font-size: 1.1rem;
      color: #16794a;
      font-weight: 600;
      margin: 0 auto 1rem;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }
    .subtitle {
      color: #555;
      max-width: 540px;
      margin: 0 auto 2rem;
      font-size: 1.05rem;
    }
    .hero-ctas {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .cta {
      display: inline-block;
      background: #16794a;
      color: white;
      padding: 0.75rem 1.6rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      transition: background 0.2s;
    }
    .cta:hover {
      background: #0f5c37;
    }
    .cta-secondary {
      background: transparent;
      color: #16794a;
      border: 2px solid #16794a;
    }
    .cta-secondary:hover {
      background: #f0faf5;
    }
    .benefits {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.5rem;
      margin: 2.5rem 0;
    }
    .benefit-card {
      background: #f8fffe;
      border: 1px solid #d4eddf;
      border-radius: 10px;
      padding: 1.5rem;
      text-align: center;
    }
    .benefit-icon {
      font-size: 2rem;
      display: block;
      margin-bottom: 0.5rem;
    }
    .benefit-card h3 {
      margin: 0 0 0.5rem;
      color: #16794a;
    }
    .benefit-card p {
      margin: 0;
      color: #555;
      font-size: 0.95rem;
    }
    .post-list {
      list-style: none;
      padding: 0;
    }
    .post-list li {
      padding: 1rem 0;
      border-bottom: 1px solid #eee;
    }
    .post-list a {
      font-size: 1.1rem;
      font-weight: 600;
      color: #1a1a1a;
      text-decoration: none;
    }
    .post-list a:hover {
      color: #16794a;
    }
    .post-list p {
      margin: 0.3rem 0 0;
      color: #666;
    }
  </style>
</Layout>
