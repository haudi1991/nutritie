---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title="Puie Radu — Tehnician Nutriționist">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner container">
      <img
        src="https://eu-central-1.linodeobjects.com/eatntrack-profile/users/1288657/759edf96-0983-4bd3-b6b3-a682a54bb6fb.jpg"
        alt="Puie Radu — Tehnician Nutriționist"
        class="hero-avatar"
        width="100"
        height="100"
      />
      <p class="hero-badge">✦ Tehnician Nutriționist certificat din 2021</p>
      <h1>Nutriție echilibrată,<br />adaptată vieții tale reale</h1>
      <p class="hero-sub">
        Salut, sunt <strong>Puie Radu</strong>. Te ajut să îți atingi obiectivele fără diete
        restrictive — cu educație, conștientizare și obiceiuri sustenabile.
      </p>
      <div class="hero-ctas">
        <a href="https://calendly.com/radupuie/30min" target="_blank" rel="noopener noreferrer" class="btn btn-light">Programează o consultație</a>
        <a href="/despre" class="btn btn-outline">Despre mine</a>
      </div>
      <a href="https://eatntrack.ro/coaches/radu-p" target="_blank" rel="noopener noreferrer" class="eatntrack-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Disponibil pe EatNtrack
      </a>
    </div>
    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,60 L0,60 Z" fill="#f6faf7"/>
      </svg>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="benefits-section container">
    <h2 class="section-title">Cum te pot ajuta</h2>
    <div class="benefits-grid">
      <div class="card">
        <div class="card-icon">🥗</div>
        <h3>Fără diete stricte</h3>
        <p>Adaptăm alimentația la viața ta reală, nu invers. Nicio regulă rigidă, nicio restricție extremă.</p>
      </div>
      <div class="card">
        <div class="card-icon">📚</div>
        <h3>Educație nutrițională</h3>
        <p>Înțelegi ce mănânci și de ce — iei decizii informate în loc să urmezi reguli oarbe.</p>
      </div>
      <div class="card">
        <div class="card-icon">🎯</div>
        <h3>Obiective sustenabile</h3>
        <p>Slăbit sănătos, relație mai bună cu mâncarea și obiceiuri care durează pe termen lung.</p>
      </div>
    </div>
  </section>

  <!-- MISSION STRIP -->
  <section class="mission-strip">
    <div class="container mission-inner">
      <p class="mission-label">🎯 Abordarea mea</p>
      <h2 class="mission-title">Nutriția ca aliat, nu ca sursă de stres</h2>
      <p class="mission-text">
        Lucrez cu tine ca să capeți încredere, control și liniște în jurul alimentației —
        prin înțelegere și obiceiuri adaptate vieții tale reale, nu prin reguli rigide.
      </p>
    </div>
  </section>

  <!-- BLOG -->
  <section class="blog-section container">
    <div class="blog-header">
      <h2 class="section-title">Articole recente</h2>
      {latestPosts.length > 0 && <a href="/blog" class="see-all">Vezi toate →</a>}
    </div>
    {latestPosts.length === 0 && (
      <p class="empty-state">Primele articole vor apărea aici în curând.</p>
    )}
    <ul class="post-list">
      {latestPosts.map((post) => (
        <li class="post-card">
          <a href={`/blog/${post.id}/`} class="post-title">{post.data.title}</a>
          <p class="post-desc">{post.data.description}</p>
          <a href={`/blog/${post.id}/`} class="post-link">Citește →</a>
        </li>
      ))}
    </ul>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner container">
    <div class="cta-banner-inner">
      <h2>Gata să faci primul pas?</h2>
      <p>Contactează-mă direct pe WhatsApp sau prin email — îți răspund rapid.</p>
      <div class="cta-banner-btns">
        <a href="https://wa.me/40724212779" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
        <a href="mailto:puieradu14@gmail.com" class="btn btn-email">Email</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ---- HERO ---- */
  .hero {
    background: linear-gradient(135deg, #052e16 0%, #0b3d2e 50%, #166534 100%);
    color: #fff;
    padding: 5rem 0 0;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 360px; height: 360px;
    background: radial-gradient(circle, rgba(34,197,94,0.15) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .hero-inner {
    padding-bottom: 4rem;
    text-align: center;
    position: relative;
  }
  .hero-avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(255,255,255,0.25);
    box-shadow: 0 4px 24px rgba(0,0,0,0.3);
    margin-bottom: 1.25rem;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.12);
    color: #86efac;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.35rem 1rem;
    border-radius: 99px;
    border: 1px solid rgba(134,239,172,0.3);
    margin-bottom: 1.5rem;
  }
  .eatntrack-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.5rem;
    color: rgba(255,255,255,0.55);
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.15);
    padding: 0.35rem 0.85rem;
    border-radius: 99px;
    transition: all 0.15s;
  }
  .eatntrack-link:hover {
    color: rgba(255,255,255,0.9);
    border-color: rgba(255,255,255,0.35);
    background: rgba(255,255,255,0.06);
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 1.2rem;
    line-height: 1.15;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.8);
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .hero-sub strong {
    color: #fff;
  }
  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .hero-wave {
    line-height: 0;
    margin-top: -1px;
  }
  .hero-wave svg {
    width: 100%; height: 60px; display: block;
  }

  /* ---- BUTTONS ---- */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.97rem;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
  }
  .btn-light {
    background: #fff;
    color: #0b3d2e;
  }
  .btn-light:hover {
    background: #f0fdf4;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .btn-outline {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.5);
  }
  .btn-outline:hover {
    border-color: #fff;
    background: rgba(255,255,255,0.08);
  }
  .btn-whatsapp {
    background: #25d366;
    color: #fff;
  }
  .btn-whatsapp:hover {
    background: #1db954;
    transform: translateY(-1px);
  }
  .btn-email {
    background: var(--green-600, #16803d);
    color: #fff;
  }
  .btn-email:hover {
    background: #0f5c37;
    transform: translateY(-1px);
  }

  /* ---- SECTIONS ---- */
  .benefits-section {
    padding: 4rem 1.5rem;
  }
  .section-title {
    font-size: 1.6rem;
    color: #111827;
    margin-bottom: 2rem;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .card {
    background: #fff;
    border-radius: 14px;
    padding: 1.75rem 1.5rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
  }
  .card-icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }
  .card h3 {
    font-size: 1.05rem;
    color: #0b3d2e;
    margin-bottom: 0.5rem;
  }
  .card p {
    color: #6b7280;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* ---- MISSION STRIP ---- */
  .mission-strip {
    background: linear-gradient(135deg, #0b3d2e, #166534);
    padding: 3.5rem 1.5rem;
    color: #fff;
  }
  .mission-inner {
    text-align: center;
  }
  .mission-label {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #86efac;
    margin-bottom: 0.75rem;
  }
  .mission-title {
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 1rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .mission-text {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.78);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ---- BLOG ---- */
  .blog-section {
    padding: 4rem 1.5rem;
  }
  .blog-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .blog-header .section-title {
    margin-bottom: 0;
  }
  .see-all {
    color: #16803d;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .see-all:hover { text-decoration: underline; }
  .empty-state {
    color: #6b7280;
    background: #fff;
    padding: 2rem;
    border-radius: 12px;
    text-align: center;
  }
  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .post-card {
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: box-shadow 0.2s;
  }
  .post-card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.1); }
  .post-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #111827;
    text-decoration: none;
    display: block;
    margin-bottom: 0.4rem;
  }
  .post-title:hover { color: #16803d; }
  .post-desc {
    color: #6b7280;
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
  }
  .post-link {
    color: #16803d;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }
  .post-link:hover { text-decoration: underline; }

  /* ---- CTA BANNER ---- */
  .cta-banner {
    padding: 0 1.5rem 4rem;
  }
  .cta-banner-inner {
    background: #fff;
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: center;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    border: 1px solid #dcfce7;
  }
  .cta-banner-inner h2 {
    font-size: 1.5rem;
    color: #0b3d2e;
    margin-bottom: 0.75rem;
  }
  .cta-banner-inner p {
    color: #6b7280;
    margin-bottom: 1.75rem;
  }
  .cta-banner-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

</Layout>
