---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title="Puie Radu — Tehnician Nutriționist">

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-grid container">

      <!-- Left col: text -->
      <div class="hero-text">
        <span class="eyebrow">✦ Tehnician Nutriționist · Diplomă 2021</span>
        <h1>Nutriție<br /><em>echilibrată</em>,<br />fără stres</h1>
        <p class="hero-sub">
          Salut, sunt <strong>Puie Radu</strong>. Te ajut să slăbești sănătos,
          să îți îmbunătățești relația cu mâncarea și să construiești obiceiuri
          care funcționează pe termen lung — fără diete restrictive.
        </p>
        <div class="hero-ctas">
          <a href="https://calendly.com/radupuie/30min" target="_blank" rel="noopener noreferrer" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Programează — prima consultație e gratuită
          </a>
          <a href="https://wa.me/40724212779" target="_blank" rel="noopener noreferrer" class="btn-ghost">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
        <div class="trust-pills">
          <span>🟢 Online</span>
          <span>� Prima consultație gratuită</span>
          <span>✅ Fără diete stricte</span>
        </div>
        <a href="https://eatntrack.ro/coaches/radu-p" target="_blank" rel="noopener noreferrer" class="eatntrack-inline">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Disponibil pe EatNtrack
        </a>
      </div>

      <!-- Right col: photo -->
      <div class="hero-photo-wrap">
        <div class="photo-ring">
          <img
            src="https://eu-central-1.linodeobjects.com/eatntrack-profile/users/1288657/759edf96-0983-4bd3-b6b3-a682a54bb6fb.jpg"
            alt="Puie Radu — Tehnician Nutriționist"
            class="hero-photo"
            width="300"
            height="300"
          />
          <div class="photo-card photo-card--top">
            <span class="photo-card-icon">🏅</span>
            <div>
              <strong>Certificat</strong>
              <span>din 2021</span>
            </div>
          </div>
          <div class="photo-card photo-card--bottom">
            <span class="photo-card-icon">🌿</span>
            <div>
              <strong>100% Online</strong>
              <span>Oriunde în România</span>
            </div>
          </div>
        </div>
      </div>

    </div>
    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,35 C480,70 960,0 1440,35 L1440,70 L0,70 Z" fill="#f8f7f4"/>
      </svg>
    </div>
  </section>

  <!-- ═══ HOW I CAN HELP ═══ -->
  <section class="section-pad container">
    <div class="section-header centered">
      <p class="section-eyebrow">Servicii</p>
      <h2 class="section-title">Cum te pot ajuta</h2>
      <p class="section-sub">Nu există o rețetă universală. Lucrez diferit cu fiecare persoană.</p>
    </div>
    <div class="benefits-grid">
      <div class="bcard">
        <div class="bcard-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Fără diete stricte</h3>
        <p>Adaptăm alimentația la viața ta reală — fără interdicții extreme.</p>
      </div>
      <div class="bcard">
        <div class="bcard-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
        </div>
        <h3>Educație nutrițională</h3>
        <p>Înțelegi ce mănânci și de ce — iei decizii informate, nu urmezi reguli oarbe.</p>
      </div>
      <div class="bcard">
        <div class="bcard-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <h3>Progres sustenabil</h3>
        <p>Slăbit sănătos și obiceiuri care durează — nu efectul yo-yo, ci schimbări reale pe termen lung.</p>
      </div>
    </div>
  </section>

  <!-- ═══ APPROACH STRIP ═══ -->
  <section class="approach-strip">
    <div class="container approach-inner">
      <div class="approach-text">
        <p class="section-eyebrow light">Filozofia mea</p>
        <h2>Nutriția ca aliat,<br />nu ca sursă de stres</h2>
        <p>Lucrez cu tine ca să capeți încredere și control în jurul alimentației — prin înțelegere și obiceiuri adaptate vieții tale, nu prin reguli rigide.</p>
        <a href="/despre" class="btn-ghost-light">Află mai multe despre mine →</a>
      </div>
      <div class="approach-stats">
        <div class="stat">
          <strong>100%</strong>
          <span>Online</span>
        </div>
        <div class="stat">
          <strong>1:1</strong>
          <span>Personalizat</span>
        </div>
        <div class="stat">
          <strong>0</strong>
          <span>Interdicții extreme</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BLOG ═══ -->
  <section class="section-pad container">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">Resurse</p>
        <h2 class="section-title">Articole recente</h2>
      </div>
      {latestPosts.length > 0 && <a href="/blog" class="see-all">Vezi toate articolele →</a>}
    </div>
    {latestPosts.length === 0 ? (
      <div class="empty-blog">
        <span>📝</span>
        <p>Primele articole vor apărea în curând.</p>
      </div>
    ) : (
      <ul class="post-list">
        {latestPosts.map((post) => (
          <li class="post-card">
            <div class="post-card-inner">
              <a href={`/blog/${post.id}/`} class="post-title">{post.data.title}</a>
              <p class="post-desc">{post.data.description}</p>
            </div>
            <a href={`/blog/${post.id}/`} class="post-arrow" aria-label="Citește articolul">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>

  <!-- ═══ FINAL CTA ═══ -->
  <section class="final-cta-wrap container">
    <div class="final-cta">
      <div class="final-cta-text">
        <div class="free-badge">🎁 Prima consultație este gratuită</div>
        <h2>Gata să faci primul pas?</h2>
        <p>Programează o întâlnire de 30 de minute — fără costuri, fără obligații. Vedem împreună cum te pot ajuta.</p>
      </div>
      <div class="final-cta-actions">
        <a href="https://calendly.com/radupuie/30min" target="_blank" rel="noopener noreferrer" class="btn-primary btn-primary--lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Programează pe Calendly
        </a>
        <div class="alt-contacts">
          <a href="https://wa.me/40724212779" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <span class="divider">·</span>
          <a href="mailto:puieradu14@gmail.com">puieradu14@gmail.com</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Tokens, reset, .btn-primary, .btn-ghost → src/styles/global.css */

  /* ─── HERO ─── */
  .hero {
    background: linear-gradient(140deg, var(--ink-950) 0%, var(--ink-900) 55%, var(--ink-800) 100%);
    position: relative;
    overflow: hidden;
    padding-top: 1rem;
  }
  /* subtle radial glows */
  .hero::before,
  .hero::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }
  .hero::before {
    width: 500px; height: 500px;
    top: -140px; right: -120px;
    background: radial-gradient(circle, rgba(20,184,166,.18) 0%, transparent 65%);
  }
  .hero::after {
    width: 300px; height: 300px;
    bottom: 60px; left: -80px;
    background: radial-gradient(circle, rgba(99,102,241,.10) 0%, transparent 65%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: 4rem 1.5rem 2rem;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 780px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      padding: 5rem 1.5rem 2.5rem;
      gap: 2rem;
    }
  }

  .hero-text {
    color: var(--surface);
  }
  .eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent-lit);
    margin-bottom: 1.1rem;
  }
  .hero-text h1 {
    font-size: clamp(2.4rem, 5.5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--surface);
    margin-bottom: 1.25rem;
  }
  .hero-text h1 em {
    font-style: normal;
    background: linear-gradient(90deg, var(--accent-lit), var(--accent-mid));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,.78);
    line-height: 1.75;
    max-width: 440px;
    margin-bottom: 2rem;
  }
  .hero-sub strong { color: var(--surface); }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .trust-pills {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .trust-pills span {
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255,255,255,.60);
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.12);
    padding: 0.3rem 0.7rem;
    border-radius: 99px;
  }
  .eatntrack-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(255,255,255,.45);
    border: 1px solid rgba(255,255,255,.13);
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    text-decoration: none;
    transition: all 0.15s;
    width: fit-content;
  }
  .eatntrack-inline:hover {
    color: rgba(255,255,255,.85);
    border-color: rgba(255,255,255,.3);
    background: rgba(255,255,255,.06);
  }

  /* Photo col */
  .hero-photo-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  @media (min-width: 780px) {
    .hero-photo-wrap { align-items: flex-end; }
  }

  .photo-ring {
    position: relative;
    width: 260px;
    height: 260px;
  }
  @media (min-width: 780px) {
    .photo-ring { width: 300px; height: 300px; }
  }
  .hero-photo {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    border: 4px solid rgba(255,255,255,.2);
    box-shadow: 0 20px 60px rgba(0,0,0,.4);
    display: block;
  }

  /* Floating cards on photo */
  .photo-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,.12);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 12px;
    padding: 0.5rem 0.85rem;
    color: var(--surface);
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .photo-card strong { display: block; font-size: 0.85rem; font-weight: 700; }
  .photo-card span { display: block; color: rgba(255,255,255,.65); font-size: 0.72rem; }
  .photo-card-icon { font-size: 1.2rem; }
  .photo-card--top  { top: 4px; right: -20px; }
  .photo-card--bottom { bottom: 16px; left: -20px; }
  @media (max-width: 779px) {
    .photo-card--top  { top: 4px; right: -8px; }
    .photo-card--bottom { bottom: 16px; left: -8px; }
  }

  .eatntrack-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(255,255,255,.5);
    border: 1px solid rgba(255,255,255,.15);
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    text-decoration: none;
    transition: all 0.15s;
  }
  .eatntrack-badge:hover {
    color: var(--surface);
    border-color: rgba(255,255,255,.35);
    background: rgba(255,255,255,.07);
  }

  .hero-wave {
    line-height: 0;
    margin-top: 1rem;
    position: relative;
    z-index: 1;
  }
  .hero-wave svg { width: 100%; height: 70px; display: block; }

  /* ─── BUTTONS (page-specific only) ─── */
  /* .btn-primary și .btn-ghost sunt în global.css */
  .btn-primary--lg {
    padding: 0.9rem 2rem;
    font-size: 1rem;
    background: linear-gradient(135deg, var(--accent), var(--ink-800));
    color: var(--surface);
    box-shadow: none;
  }
  .btn-primary--lg:hover {
    background: linear-gradient(135deg, var(--ink-800), var(--ink-950));
    transform: translateY(-2px);
  }
  .btn-ghost-light {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--accent-lit);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    margin-top: 1.25rem;
    transition: color 0.15s;
  }
  .btn-ghost-light:hover { color: var(--surface); }

  /* ─── SHARED SECTION STYLES ─── */
  /* .section-title și .eyebrow sunt în global.css */
  .section-pad {
    padding: 5rem 1.5rem;
  }
  .section-sub {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 480px;
    margin-top: 0.5rem;
  }
  .see-all {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .see-all:hover { text-decoration: underline; }

  /* ─── BENEFITS ─── */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .bcard {
    background: var(--surface);
    border-radius: var(--r-md);
    padding: 2rem 1.75rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .bcard:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }
  .bcard-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--accent-50);
    border: 1px solid var(--accent-100);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    color: var(--accent);
  }
  .bcard h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  .bcard p {
    color: var(--text-muted);
    font-size: 0.93rem;
    line-height: 1.65;
  }

  /* ─── APPROACH STRIP ─── */
  .approach-strip {
    background: linear-gradient(135deg, var(--ink-950) 0%, var(--ink-800) 100%);
    padding: 5rem 1.5rem;
    color: var(--surface);
  }
  .approach-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 720px) {
    .approach-inner {
      grid-template-columns: 1.4fr 1fr;
      align-items: center;
    }
  }
  .approach-text h2 {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 800;
    color: var(--surface);
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }
  .approach-text p {
    color: rgba(255,255,255,.72);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 440px;
  }
  .approach-stats {
    display: flex;
    flex-direction: row;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  @media (min-width: 720px) {
    .approach-stats {
      flex-direction: column;
