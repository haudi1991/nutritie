---
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
}
const { eyebrow, title, intro } = Astro.props;
---

<div class="page-header">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  {intro && <p class="page-intro">{intro}</p>}
</div>

<style>
  .page-header {
    margin-bottom: 2rem;
  }
  h1 {
    font-size: 2.2rem;
    margin: 0.25rem 0 0.5rem;
  }
  .page-intro {
    color: var(--text-muted);
    font-size: 1rem;
    max-width: 520px;
    margin: 0;
  }
</style>
