---
interface Props {
  num: number;
  title: string;
  description: string;
  tags?: string[];
}
const { num, title, description, tags = [] } = Astro.props;
---

<div class="step-card">
  <div class="step-num">{num}</div>
  <div class="step-body">
    <h3>{title}</h3>
    <p set:html={description} />
    {tags.length > 0 && (
      <div class="step-tags">
        {tags.map(tag => <span>{tag}</span>)}
      </div>
    )}
  </div>
</div>

<style>
  .step-card {
    display: flex;
    gap: 1.25rem;
    background: var(--surface);
    border-radius: var(--r-md);
    padding: 1.75rem;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .step-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent-100);
  }
  .step-num {
    width: 36px;
    height: 36px;
    min-width: 36px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-weight: 800;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.1rem;
  }
  .step-body h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  .step-body p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
    margin-bottom: 1rem;
  }
  .step-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .step-tags span {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-50);
    border: 1px solid var(--accent-100);
    padding: 0.2rem 0.55rem;
    border-radius: 99px;
  }
</style>
