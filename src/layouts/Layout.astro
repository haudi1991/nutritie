---
interface Props {
  title: string;
  description?: string;
  padded?: boolean;
}

const { title, description = 'Tehnician nutritionist pasionat de nutriția echilibrată și schimbări sustenabile ale stilului de viață. Te ajut să îți atingi obiectivele fără diete restrictive.', padded = false } = Astro.props;
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav-inner">
        <a href="/" class="logo">
          <span class="logo-icon">🌿</span>
          Puie Radu
        </a>
        <div class="nav-links">
          <a href="/">Acasă</a>
          <a href="/blog">Blog</a>
          <a href="/despre">Despre mine</a>
          <a href="/contact" class="nav-cta">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      {padded ? (
        <div class="page-pad"><slot /></div>
      ) : (
        <slot />
      )}
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="logo-icon">🌿</span>
          <strong>Puie Radu</strong>
          <span class="footer-subtitle">Tehnician Nutriționist</span>
        </div>
        <nav class="footer-nav">
          <a href="/">Acasă</a>
          <a href="/blog">Blog</a>
          <a href="/despre">Despre mine</a>
          <a href="/contact">Contact</a>
        </nav>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Puie Radu. Toate drepturile rezervate.</p>
      </div>
    </footer>

    <style>
      :global(:root) {
        --ink-950: #0d1117;
        --ink-800: #1e2d3d;
        --ink-700: #243447;
        --teal-600: #0d9488;
        --teal-500: #14b8a6;
        --teal-200: #99f6e4;
        --teal-100: #ccfbf1;
        --teal-50:  #f0fdfa;
        --bg: #f8f7f4;
        --surface: #ffffff;
        --text: #111827;
        --text-muted: #6b7280;
        --radius: 12px;
        --shadow: 0 2px 16px rgba(0,0,0,0.07);
        --shadow-hover: 0 8px 32px rgba(0,0,0,0.13);
      }
      :global(*) {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :global(body) {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.6;
      }
      :global(.container) {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      :global(h1), :global(h2), :global(h3) {
        font-weight: 700;
        line-height: 1.2;
      }
      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: var(--ink-950);
        box-shadow: 0 1px 0 rgba(255,255,255,.06);
      }
      .nav-inner {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 1.5rem;
        height: 64px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-weight: 700;
        font-size: 1.15rem;
        color: #ffffff;
        text-decoration: none;
        letter-spacing: -0.01em;
      }
      .logo-icon {
        font-size: 1.3rem;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }
      .nav-links a {
        color: rgba(255,255,255,0.8);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        padding: 0.4rem 0.75rem;
        border-radius: 6px;
        transition: all 0.15s;
      }
      .nav-links a:hover {
        color: #ffffff;
        background: rgba(255,255,255,0.1);
      }
      .nav-cta {
        background: var(--teal-500) !important;
        color: #fff !important;
        font-weight: 600 !important;
        padding: 0.45rem 1rem !important;
        border-radius: 8px !important;
      }
      .nav-cta:hover {
        background: var(--teal-600) !important;
        color: #fff !important;
      }
      main {
        min-height: 60vh;
      }
      .page-pad {
        max-width: 860px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem;
      }
      .site-footer {
        background: var(--ink-950);
        color: rgba(255,255,255,0.7);
        padding: 2.5rem 1.5rem;
        margin-top: 4rem;
      }
      .footer-inner {
        max-width: 860px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        text-align: center;
      }
      .footer-brand {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.05rem;
        color: #fff;
      }
      .footer-subtitle {
        color: rgba(255,255,255,0.5);
        font-size: 0.9rem;
        margin-left: 0.25rem;
      }
      .footer-nav {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        justify-content: center;
      }
      .footer-nav a {
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.15s;
      }
      .footer-nav a:hover {
        color: #fff;
      }
      .footer-copy {
        font-size: 0.8rem;
        color: rgba(255,255,255,0.35);
      }
    </style>
  </body>
</html>
