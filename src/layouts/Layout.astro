---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Sfaturi de nutriție bazate pe știință.' } = Astro.props;
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="logo">Numele Tău</a>
        <div class="nav-links">
          <a href="/">Acasă</a>
          <a href="/blog">Blog</a>
          <a href="/despre">Despre mine</a>
          <a href="/contact">Contact</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Numele Tău — Nutriționist atestat</p>
    </footer>

    <style>
      :global(*) {
        box-sizing: border-box;
      }
      :global(body) {
        margin: 0;
        font-family: system-ui, -apple-system, sans-serif;
        color: #1a1a1a;
        line-height: 1.6;
      }
      .site-header {
        border-bottom: 1px solid #eee;
        padding: 1rem 2rem;
      }
      nav {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .logo {
        font-weight: bold;
        font-size: 1.2rem;
        color: #1a1a1a;
        text-decoration: none;
      }
      .nav-links {
        display: flex;
        gap: 1.5rem;
      }
      .nav-links a {
        color: #444;
        text-decoration: none;
      }
      .nav-links a:hover {
        color: #16794a;
      }
      main {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
        min-height: 60vh;
      }
      .site-footer {
        text-align: center;
        padding: 2rem;
        color: #888;
        font-size: 0.9rem;
        border-top: 1px solid #eee;
      }
    </style>
  </body>
</html>
